rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Posts collection
    match /posts/{postId} {
      // Anyone can read posts
      allow read: if true;
      
      // Only authenticated users can create posts, and userId must match their own
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Only the author can edit or delete their own posts
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Default fallback
    // Allow read/write to all collections for authenticated users (Temporary ease for development)
    // Production rules should be tighter, but this ensures functionality for now.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
